{
  "name": "Bobbo",
  "port": 8080,
  "agentDir": "/root/bobbo-agent/agent",
  "cronFile": "/etc/cron.d/bobbo",
  "lockFile": "/tmp/bobbo.lock",
  "pidFile": "/tmp/bobbo-review-server.pid",
  "authors": {
    "rob":   { "color": "#1565c0", "bg": "#e3f2fd" },
    "bobbo": { "color": "#4527a0", "bg": "#ede7f6" }
  },
  "sidebar": {
    "type": "projects",
    "projectsDir": "projects",
    "runningLog": true
  },
  "features": {
    "tabs": ["journal", "outputs", "project"],
    "outputs": true,
    "feedback": true,
    "deploy": true,
    "serviceRestart": ["review-server", "telegram-poller"]
  }
}
